generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum Discipline {
  KITESURF
  WINGFOIL
  WINDSURF
  FOILBOARD
  KITEFOIL
  WAKEBOARD
  PADDLE
  WATERWEAR
}

enum EquipmentType {
  COMETA
  WING
  TABLA
  BARRA_LINEAS
  LEASH
  FOIL
  ARNES
  TRAJE
  ACCESORIO
  COMBO
  ACC_COMETA
  ACC_WING
  ACC_BARRA
  ACC_TABLA
  ACC_ARNES
  BOMBAS
  MALETAS
  WETSUIT
  PONCHO
  PROTECCION
  TECNOLOGIA
  OTROS
}

enum Condition {
  NUEVO
  COMO_NUEVO
  USADO
}

enum ListingStatus {
  DRAFT
  ACTIVE
  SOLD
  PAUSED
  REMOVED
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

// ─── User ────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password      String?
  phone         String?
  idDoc         String?
  address       String?
  city          String?
  department    String?
  bio           String?
  bankName          String?
  bankAccountType   String?   // "ahorros" | "corriente"
  bankAccountNumber String?
  bankAccountHolder String?
  bankIdDoc         String?   // cédula del titular de la cuenta
  verified            Boolean   @default(false)
  verificationStatus  String    @default("NONE")  // NONE | PENDING | APPROVED | REJECTED
  verificationIdUrl   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // NextAuth
  accounts      Account[]
  sessions      Session[]

  // Marketplace
  listings             Listing[]
  reviews              Review[]       @relation("ReviewsReceived")
  reviewsGiven         Review[]       @relation("ReviewsGiven")
  favorites            Favorite[]
  conversationsAsBuyer  Conversation[] @relation("ConversationsBuyer")
  conversationsAsSeller Conversation[] @relation("ConversationsSeller")
  messagesSent          Message[]      @relation("MessagesSent")
  ordersAsBuyer         Order[]        @relation("OrdersBuyer")
  ordersAsSeller        Order[]        @relation("OrdersSeller")

  @@map("users")
}

// ─── NextAuth ────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Listing ─────────────────────────────────────────────

model Listing {
  id            String        @id @default(cuid())
  title         String
  description   String        @db.Text
  price         Int           // COP, en pesos enteros
  discipline    Discipline
  equipmentType EquipmentType
  condition     Condition
  brand         String?
  size          String?
  city          String
  metadata      Json?         // Campos extra según disciplina/tipo
  currency      String        @default("COP") // "COP" | "USD"
  status        ListingStatus @default(ACTIVE)
  featured      Boolean       @default(false)
  views         Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  sellerId      String
  seller        User          @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  images        ListingImage[]
  favoritedBy   Favorite[]
  conversations Conversation[]
  orders        Order[]

  @@index([discipline])
  @@index([equipmentType])
  @@index([status])
  @@index([sellerId])
  @@map("listings")
}

// ─── Favorites ───────────────────────────────────────────

model Favorite {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@map("favorites")
}

model ListingImage {
  id         String   @id @default(cuid())
  url        String
  publicId   String?  // Cloudinary public ID para poder borrarla
  order      Int      @default(0)
  listingId  String
  listing    Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@map("listing_images")
}

// ─── Messaging ───────────────────────────────────────────

model Conversation {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  listingId String
  listing   Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)

  buyerId   String
  buyer     User      @relation("ConversationsBuyer",  fields: [buyerId],  references: [id], onDelete: Cascade)

  sellerId  String
  seller    User      @relation("ConversationsSeller", fields: [sellerId], references: [id], onDelete: Cascade)

  messages  Message[]

  @@unique([listingId, buyerId])
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  content        String       @db.Text
  createdAt      DateTime     @default(now())
  readAt         DateTime?

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderId       String
  sender         User         @relation("MessagesSent", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("messages")
}

// ─── Reviews ─────────────────────────────────────────────

model Review {
  id         String   @id @default(cuid())
  rating     Int      // 1-5
  comment    String?
  createdAt  DateTime @default(now())

  reviewerId String
  reviewer   User     @relation("ReviewsGiven",    fields: [reviewerId], references: [id])
  subjectId  String
  subject    User     @relation("ReviewsReceived", fields: [subjectId],  references: [id])

  orderId    String?  @unique
  order      Order?   @relation(fields: [orderId], references: [id])

  @@map("reviews")
}

// ─── Orders ──────────────────────────────────────────────

model Order {
  id            String      @id @default(cuid())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  listingId     String
  listing       Listing     @relation(fields: [listingId], references: [id])

  buyerId       String
  buyer         User        @relation("OrdersBuyer", fields: [buyerId], references: [id])

  sellerId      String
  seller        User        @relation("OrdersSeller", fields: [sellerId], references: [id])

  status        OrderStatus @default(PENDING)
  amount        Int

  buyerName     String
  buyerIdDoc    String
  buyerPhone    String
  buyerCity     String
  buyerAddress  String

  shippedAt        DateTime?
  deliveredAt      DateTime?
  deliveryDeadline DateTime?
  shippingProofUrl String?
  review           Review?

  sellerBankName          String?
  sellerBankAccountType   String?
  sellerBankAccountNumber String?
  sellerBankAccountHolder String?
  sellerBankIdDoc         String?

  paymentMethod           String  @default("manual") // "manual" | "wompi"
  wompiReference          String? @unique
  wompiTransactionId      String?

  @@map("orders")
}

// ─── Password Reset ───────────────────────────────────────

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}
